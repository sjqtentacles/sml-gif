(* MLB for the sml-gif library: the vendored sml-image core (which itself pulls
 * in sml-inflate and sml-color) plus the GIF encoder sources. Consumers
 * reference this file.
 *
 * The dependency .mlb is brought in WITHOUT a `local` wrapper so that consumers
 * (the test suite, examples) can `open Image` alongside Gif if desired. *)
$(SML_LIB)/basis/basis.mlb
../lib/github.com/sjqtentacles/sml-image/image.mlb
gif.sig
gif.sml
